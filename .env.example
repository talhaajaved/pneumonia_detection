# Django Settings
DJANGO_SECRET_KEY=your-super-secret-key-change-this
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Security
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=31536000

# API throttling
API_RATE_LIMIT=20
API_RATE_WINDOW_SECONDS=60

# Inference pipeline toggles
ENABLE_XRAY_VALIDATION=True
ENABLE_LUNG_SEGMENTATION=True
ENABLE_GRADCAM=True
USE_TTA=True
MIN_SEGMENTATION_CHECKS=3

# Database (optional - using SQLite by default)
# DATABASE_URL=postgres://user:password@localhost:5432/pneumonia_db
